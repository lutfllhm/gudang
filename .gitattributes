# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# Configuration files
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documentation
*.md text eol=lf

# Docker files
Dockerfile text eol=lf
.dockerignore text eol=lf
docker-compose*.yml text eol=lf

# Environment files
.env* text eol=lf

# SQL files
*.sql text eol=lf

# JavaScript/Node.js
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Exclude files from export
.gitattributes export-ignore
.gitignore export-ignore
