# =================================
# SERVER CONFIGURATION
# =================================
NODE_ENV=production
PORT=5000
APP_NAME=iWare Warehouse

# =================================
# DATABASE CONFIGURATION
# =================================
# Untuk Docker: gunakan nama service 'mysql'
# Untuk local: gunakan '127.0.0.1' atau 'localhost'
DB_HOST=mysql
DB_PORT=3306
DB_USER=iware_user
DB_PASSWORD=your_strong_db_password_change_me
DB_NAME=iware_warehouse
DB_CONNECTION_LIMIT=10

# =================================
# JWT CONFIGURATION
# =================================
# Generate secret yang kuat minimal 32 karakter
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_change_me
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_me
JWT_REFRESH_EXPIRE=30d

# =================================
# ACCURATE ONLINE API CONFIGURATION
# =================================
# URL Accurate Online (jangan diubah)
ACCURATE_ACCOUNT_URL=https://account.accurate.id
ACCURATE_API_URL=https://public-api.accurate.id/api

# Kredensial Aplikasi Accurate Online
# Dapatkan dari: https://account.accurate.id/developer/application
ACCURATE_APP_KEY=your_app_key_from_accurate_developer_portal
ACCURATE_CLIENT_ID=your_client_id_from_accurate_developer_portal
ACCURATE_CLIENT_SECRET=your_client_secret_from_accurate_developer_portal

# Redirect URI untuk OAuth callback
# Harus sama dengan yang didaftarkan di Accurate Developer Portal
ACCURATE_REDIRECT_URI=https://iwareid.com/api/accurate/callback

# Signature Secret untuk webhook validation
# Dapatkan dari Accurate Developer Portal
ACCURATE_SIGNATURE_SECRET=your_signature_secret_from_accurate

# Access Token & Database ID
# Akan didapat setelah proses OAuth authorization
# Bisa dikosongkan dulu, akan diisi otomatis setelah login
ACCURATE_ACCESS_TOKEN=
ACCURATE_DATABASE_ID=

# =================================
# REDIS CONFIGURATION
# =================================
# Untuk Docker: gunakan nama service 'redis'
# Untuk local: gunakan '127.0.0.1' atau 'localhost'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me_in_production
REDIS_DB=0

# =================================
# CORS CONFIGURATION
# =================================
# Sesuaikan dengan domain frontend Anda
# Untuk development: http://localhost:5173
# Untuk production: https://iwareid.com
CORS_ORIGIN=https://iwareid.com
CORS_CREDENTIALS=true

# =================================
# RATE LIMITING
# =================================
# Window dalam milliseconds (900000 = 15 menit)
RATE_LIMIT_WINDOW_MS=900000
# Maksimal request per window
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# LOGGING
# =================================
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_FILES=14d

# =================================
# SYNC CONFIGURATION
# =================================
# Auto sync dengan Accurate Online
AUTO_SYNC_ENABLED=true
# Interval sync dalam detik (300 = 5 menit)
SYNC_INTERVAL_SECONDS=300
# Jumlah data per batch sync
SYNC_BATCH_SIZE=100

# =================================
# WEBHOOK CONFIGURATION
# =================================
# Secret untuk validasi webhook dari Accurate
# Generate secret yang kuat
WEBHOOK_SECRET=your_webhook_secret_here_change_me

# =================================
# TTS CONFIGURATION (ElevenLabs)
# =================================
# Dapatkan API key dari: https://elevenlabs.io → Profile → API Key
# Jika kosong, sistem akan fallback ke Google Translate TTS (gratis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID dari ElevenLabs — cek di https://elevenlabs.io/voice-library
# Default: "Bella" (multilingual, cocok untuk announcement)
# Rekomendasi lain: Rachel = 21m00Tcm4TlvDq8ikWAM, Adam = pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Model TTS — eleven_multilingual_v2 paling natural untuk Bahasa Indonesia
ELEVENLABS_MODEL=eleven_multilingual_v2
