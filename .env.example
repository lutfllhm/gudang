# Application Environment
NODE_ENV=production

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_USER=iware
DB_PASSWORD=iware_password
DB_NAME=iware_warehouse
DB_CONNECTION_LIMIT=10

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_characters
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Accurate Online Integration
ACCURATE_APP_KEY=your_accurate_app_key
ACCURATE_CLIENT_ID=your_accurate_client_id
ACCURATE_CLIENT_SECRET=your_accurate_client_secret
# Development: http://localhost:3000/auth/callback
# Production (iwareid.com): https://iwareid.com/api/accurate/callback (sesuai route backend)
ACCURATE_REDIRECT_URI=http://localhost:3000/auth/callback
ACCURATE_SIGNATURE_SECRET=your_accurate_signature_secret
ACCURATE_ACCESS_TOKEN=your_accurate_access_token
ACCURATE_DATABASE_ID=your_accurate_database_id

# Server Configuration
PORT=5000
APP_NAME=iWare Warehouse
LOG_LEVEL=info

# CORS Configuration
# Development: http://localhost:3000,http://localhost:5000
# Production (iwareid.com): https://iwareid.com,https://www.iwareid.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true
