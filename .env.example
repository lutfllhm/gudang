# ================================
# DEVELOPMENT ENVIRONMENT
# ================================
# File ini untuk development/testing lokal
# Untuk production, gunakan .env.production sebagai template

# =================================
# APPLICATION
# =================================
NODE_ENV=development
PORT=5000
APP_NAME=iWare Warehouse

# =================================
# DATABASE - MySQL
# =================================
# Untuk Docker: gunakan nama service 'mysql'
# Untuk local: gunakan 'localhost' atau '127.0.0.1'
DB_HOST=mysql
DB_PORT=3306
DB_USER=iware_user
DB_PASSWORD=sddfdsfdsfsdfdsfds
DB_NAME=iware_warehouse
DB_ROOT_PASSWORD=sdfsfsdfsdfs
DB_CONNECTION_LIMIT=10

# =================================
# REDIS CACHE
# =================================
# Untuk Docker: gunakan nama service 'redis'
# Untuk local: gunakan 'localhost' atau '127.0.0.1'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=sjifishsdfsdf
REDIS_DB=0

# =================================
# JWT SECRETS
# =================================
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Untuk development, bisa gunakan nilai sederhana
# Untuk production, WAJIB ganti dengan nilai random 64+ karakter
JWT_SECRET=dev_jwt_secret_min_32_characters_change_for_production
JWT_REFRESH_SECRET=dev_refresh_secret_min_32_characters_change_for_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# =================================
# ACCURATE ONLINE API
# =================================
# Dapatkan dari: https://account.accurate.id/developer
ACCURATE_APP_KEY=
ACCURATE_CLIENT_ID=
ACCURATE_CLIENT_SECRET=

# Redirect URI - sesuaikan dengan environment
# Development: http://localhost/api/accurate/callback
# Production: https://yourdomain.com/api/accurate/callback
ACCURATE_REDIRECT_URI=https://iwareid.com/api/accurate/callback

ACCURATE_SIGNATURE_SECRET=your_accurate_signature_secret

# Access Token & Database ID (kosongkan, akan diisi otomatis setelah OAuth)
ACCURATE_ACCESS_TOKEN=
ACCURATE_DATABASE_ID=

# =================================
# CORS CONFIGURATION
# =================================
# Development: allow localhost
# Production: ganti dengan domain production
CORS_ORIGIN=http://localhost,http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# =================================
# FRONTEND API URL
# =================================
# URL yang akan digunakan frontend untuk call API
# Development: http://localhost/api (via nginx) atau http://localhost:5000/api (direct)
# Production: https://yourdomain.com/api
VITE_API_URL=http://iwareid.com/api

# =================================
# RATE LIMITING
# =================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# LOGGING
# =================================
LOG_LEVEL=debug
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_FILES=14d

# =================================
# SYNC CONFIGURATION
# =================================
AUTO_SYNC_ENABLED=false
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=100

# =================================
# WEBHOOK
# =================================
WEBHOOK_SECRET=dev_webhook_secret_change_for_production

# =================================
# TTS (Optional - ElevenLabs)
# =================================
# Kosongkan untuk development (akan fallback ke Google TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2
