# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=iware_warehouse
DB_USER=iware_user
DB_PASSWORD=your_secure_password_here_change_this
DB_ROOT_PASSWORD=root_secure_password_change_this
DB_POOL_LIMIT=10

# ==============================================
# JWT CONFIGURATION
# ==============================================
JWT_SECRET=your_jwt_secret_key_min_32_chars_change_this
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_change_this
JWT_EXPIRE=3600
JWT_REFRESH_EXPIRE=604800

# ==============================================
# CORS & ORIGIN CONFIGURATION
# ==============================================
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ==============================================
# ACCURATE ONLINE API CONFIGURATION
# ==============================================
ACCURATE_CLIENT_ID=your_accurate_client_id
ACCURATE_CLIENT_SECRET=your_accurate_client_secret
ACCURATE_REDIRECT_URI=https://yourdomain.com/api/auth/accurate/callback

# ==============================================
# EMAIL CONFIGURATION (Optional)
# ==============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# ==============================================
# APPLICATION SETTINGS
# ==============================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
TZ=Asia/Jakarta

# ==============================================
# REDIS CONFIGURATION (for queue and caching)
# ==============================================
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=if_required

# ==============================================
# STAGING/PRODUCTION MODE
# ==============================================
# Set to 'staging' or 'production'
ENVIRONMENT=production
